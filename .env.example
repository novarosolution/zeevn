# Copy to `.env` and adjust. Expo loads `EXPO_PUBLIC_*` at build time.
# Backend default port is 5001 (see `backend/.env.example`).
# Base URL may include `/api` if you proxy that way — the server serves both `/products` and `/api/products`.

# App/build identity
APP_NAME=Zeevan
APP_SLUG=zeevan
APP_SCHEME=zeevan
APP_OWNER=novarosolution
IOS_BUNDLE_IDENTIFIER=com.zeevan.app
ANDROID_PACKAGE=com.zeevan.app
EAS_PROJECT_ID=c8f6a8ba-4547-4e67-abba-8911b03d9a55

# Public runtime branding / contact values
EXPO_PUBLIC_BRAND_NAME=Zeevan
EXPO_PUBLIC_BRAND_TAGLINE=Heritage pantry essentials, delivered beautifully
EXPO_PUBLIC_BRAND_SUBLINE=Heritage pantry
EXPO_PUBLIC_SEARCH_PLACEHOLDER=Search ghee, staples, and pantry picks...
EXPO_PUBLIC_SUPPORT_EMAIL=support@zeevan.app
EXPO_PUBLIC_SUPPORT_WHATSAPP_URL=https://wa.me/919999999999
EXPO_PUBLIC_ENGINEER_NAME=NovaRo Solution
EXPO_PUBLIC_ENGINEER_URL=https://novarosolution.com/

# Frontend integrations
EXPO_PUBLIC_API_URL=http://127.0.0.1:5001
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
EXPO_PUBLIC_RAZORPAY_PAYMENT_LINK=https://razorpay.me/@chaudharydhirajpadmabhai
