PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/zeevan
JWT_SECRET=replace_with_a_long_secret
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
CLOUDINARY_UPLOAD_PREFIX=zeevan
CLOUDINARY_AVATAR_FOLDER=zeevan/avatars
CLOUDINARY_PRODUCT_FOLDER=zeevan/products
# Razorpay (server-only secrets — never ship to client)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=replace_with_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_webhook_secret
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,https://novarosolution.com

# Google Maps Platform — Directions API (server-only). Enables road-following route on live tracking map.
# Create a key with Directions API enabled; restrict by IP on production.
# GOOGLE_MAPS_ROUTES_API_KEY=your_server_key
